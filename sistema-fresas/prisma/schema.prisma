generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CAJERA
  ADMIN
}

enum SaleStatus {
  ACTIVE
  VOIDED
}

enum PaymentMethod {
  EFECTIVO
  QR
}

enum ARStatus {
  PENDING
  PAID
}

model User {
  id             String    @id @default(uuid())
  name           String
  username       String    @unique
  hashedPassword String
  role           Role
  createdAt      DateTime  @default(now())

  sales          Sale[]    @relation("seller")
  voidedSales    Sale[]    @relation("voider")
  stockAdj       StockAdjustment[]
}

model Product {
  id    String @id @default(uuid())
  name  String @unique

  prices   Price[]
  recipes  Recipe[]
  sales    Sale[]
}

model Size {
  id    String  @id @default(uuid())
  name  String  @unique
  order Int

  prices   Price[]
  recipes  Recipe[]
  sales    Sale[]
}

model Channel {
  id            String   @id @default(uuid())
  name          String   @unique
  commissionPct Decimal  @default(0) @db.Decimal(5, 2)
  isDelivery    Boolean  @default(false)

  prices            Price[]
  sales             Sale[]
  accountReceivables AccountReceivable[]
  platformPayments  PlatformPayment[]
}

model Price {
  id        String  @id @default(uuid())
  productId String
  sizeId    String
  channelId String
  amount    Decimal @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id])
  size    Size    @relation(fields: [sizeId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id])

  @@unique([productId, sizeId, channelId])
}

model Ingredient {
  id             String  @id @default(uuid())
  name           String  @unique
  unit           String
  stock          Decimal @default(0) @db.Decimal(10, 3)
  alertThreshold Decimal @default(0) @db.Decimal(10, 3)

  recipeItems       RecipeItem[]
  saleIngredientLogs SaleIngredientLog[]
  stockAdjustments  StockAdjustment[]
}

model Recipe {
  id        String @id @default(uuid())
  productId String
  sizeId    String

  product Product      @relation(fields: [productId], references: [id])
  size    Size         @relation(fields: [sizeId], references: [id])
  items   RecipeItem[]

  @@unique([productId, sizeId])
}

model RecipeItem {
  id           String  @id @default(uuid())
  recipeId     String
  ingredientId String
  quantity     Decimal @db.Decimal(10, 3)

  recipe     Recipe     @relation(fields: [recipeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
}

model Sale {
  id            String        @id @default(uuid())
  userId        String
  productId     String
  sizeId        String
  channelId     String
  paymentMethod PaymentMethod?
  amount        Decimal       @db.Decimal(10, 2)
  status        SaleStatus    @default(ACTIVE)
  voidedAt      DateTime?
  voidedBy      String?
  createdAt     DateTime      @default(now())

  user              User                 @relation("seller", fields: [userId], references: [id])
  voidedByUser      User?                @relation("voider", fields: [voidedBy], references: [id])
  product           Product              @relation(fields: [productId], references: [id])
  size              Size                 @relation(fields: [sizeId], references: [id])
  channel           Channel              @relation(fields: [channelId], references: [id])
  ingredientLogs    SaleIngredientLog[]
  accountReceivable AccountReceivable?
}

model SaleIngredientLog {
  id           String  @id @default(uuid())
  saleId       String
  ingredientId String
  quantity     Decimal @db.Decimal(10, 3)

  sale       Sale       @relation(fields: [saleId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
}

model AccountReceivable {
  id            String   @id @default(uuid())
  saleId        String   @unique
  channelId     String
  grossAmount   Decimal  @db.Decimal(10, 2)
  commissionPct Decimal  @db.Decimal(5, 2)
  netAmount     Decimal  @db.Decimal(10, 2)
  status        ARStatus @default(PENDING)
  paymentId     String?

  sale    Sale             @relation(fields: [saleId], references: [id])
  channel Channel          @relation(fields: [channelId], references: [id])
  payment PlatformPayment? @relation(fields: [paymentId], references: [id])
}

model PlatformPayment {
  id             String   @id @default(uuid())
  channelId      String
  receivedAmount Decimal  @db.Decimal(10, 2)
  receivedAt     DateTime
  appliedAmount  Decimal  @default(0) @db.Decimal(10, 2)
  excessAmount   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  channel            Channel             @relation(fields: [channelId], references: [id])
  accountReceivables AccountReceivable[]
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  categoryId  String
  date        DateTime @db.Date
  createdAt   DateTime @default(now())

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
}

model ExpenseCategory {
  id   String @id @default(uuid())
  name String @unique

  expenses Expense[]
}

model StockAdjustment {
  id           String   @id @default(uuid())
  ingredientId String
  quantity     Decimal  @db.Decimal(10, 3)
  reason       String
  createdAt    DateTime @default(now())
  createdBy    String

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  user       User       @relation(fields: [createdBy], references: [id])
}
